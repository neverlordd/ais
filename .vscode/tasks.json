{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-shiftline",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/AIS/AIS.csproj"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "watch-shiftline",
      "type": "process",
      "command": "dotnet",
      "args": [
        "watch",
        "--project",
        "${workspaceFolder}/AIS/AIS.csproj",
        "run"
      ],
      "isBackground": true,
      "problemMatcher": "$msCompile"
    }
  ]
}
