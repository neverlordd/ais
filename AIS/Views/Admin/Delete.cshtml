@model AIS.ViewModels.Admin.UserDeleteViewModel
@{
    ViewData["Title"] = "Удаление сотрудника";
}

<div class="mx-auto max-w-3xl">
    <div class="app-form-card p-8 sm:p-10">
        <div class="app-section-header mb-8">
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-rose-500">Подтверждение удаления</p>
            <h1 class="app-section-title">Удалить сотрудника?</h1>
            <p class="app-section-description">
                Это действие удалит учетную запись сотрудника и связанную с ней историю смен.
            </p>
        </div>

        <div class="grid gap-4 rounded-[1.75rem] border border-slate-200 bg-slate-50 p-6 dark:border-slate-800 dark:bg-slate-950/80 md:grid-cols-2">
            <div>
                <p class="text-sm text-slate-500 dark:text-slate-400">ФИО</p>
                <p class="mt-1 text-lg font-semibold text-slate-950 dark:text-white">@Model.FullName</p>
            </div>
            <div>
                <p class="text-sm text-slate-500 dark:text-slate-400">Логин</p>
                <p class="mt-1 text-lg font-semibold text-slate-950 dark:text-white">@Model.Username</p>
            </div>
            <div>
                <p class="text-sm text-slate-500 dark:text-slate-400">Роль</p>
                <p class="mt-1 text-lg font-semibold text-slate-950 dark:text-white">@Model.Role.GetDisplayName()</p>
            </div>
            <div>
                <p class="text-sm text-slate-500 dark:text-slate-400">Смен в истории</p>
                <p class="mt-1 text-lg font-semibold text-slate-950 dark:text-white">@Model.ShiftsCount</p>
            </div>
        </div>

        @if (Model.IsCurrentUser)
        {
            <div class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-700 dark:border-amber-950 dark:bg-amber-950/50 dark:text-amber-200">
                Текущую учетную запись удалить нельзя.
            </div>
        }

        @if (Model.IsLastAdmin)
        {
            <div class="mt-4 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-700 dark:border-amber-950 dark:bg-amber-950/50 dark:text-amber-200">
                Это последний администратор системы. Удаление заблокировано для предотвращения потери доступа.
            </div>
        }

        @if (Model.IsOnShift)
        {
            <div class="mt-4 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700 dark:border-rose-950 dark:bg-rose-950/50 dark:text-rose-200">
                Сотрудник находится на активной смене. При удалении эта смена также будет удалена.
            </div>
        }

        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
            @if (!Model.IsCurrentUser && !Model.IsLastAdmin)
            {
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="app-button app-button-danger min-h-12 rounded-2xl px-5 text-sm font-semibold">
                        Удалить сотрудника
                    </button>
                </form>
            }

            <a asp-action="Index" class="app-button app-button-ghost min-h-12 rounded-2xl px-5 text-sm font-semibold">
                Вернуться в список
            </a>
        </div>
    </div>
</div>
