@model AIS.ViewModels.Admin.UserCreateViewModel
@{
    ViewData["Title"] = "Добавить сотрудника";
}

<div class="mx-auto max-w-4xl">
    <div class="app-form-card p-8 sm:p-10">
        <div class="app-section-header mb-8">
            <p class="app-section-kicker">Новый сотрудник</p>
            <h1 class="app-section-title">Создание учетной записи</h1>
            <p class="app-section-description">
                Заполните основные данные сотрудника. После сохранения он сможет войти в систему по выданным учетным данным.
            </p>
        </div>

        <form asp-action="Create" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="app-validation-summary"></div>

            <div class="grid gap-5 md:grid-cols-2">
                <div class="app-field md:col-span-2">
                    <label asp-for="FullName" class="app-label"></label>
                    <input asp-for="FullName" class="app-input" placeholder="Например, Иванов Иван Иванович" />
                    <span asp-validation-for="FullName" class="app-validation"></span>
                </div>

                <div class="app-field">
                    <label asp-for="Username" class="app-label"></label>
                    <input asp-for="Username" class="app-input" placeholder="Логин для входа" />
                    <span asp-validation-for="Username" class="app-validation"></span>
                </div>

                <div class="app-field">
                    <label asp-for="Role" class="app-label"></label>
                    <select asp-for="Role" asp-items="Html.GetEnumSelectList<UserRole>()" class="app-select"></select>
                    <span asp-validation-for="Role" class="app-validation"></span>
                </div>

                <div class="app-field md:col-span-2">
                    <label asp-for="Password" class="app-label"></label>
                    <input asp-for="Password" class="app-input" placeholder="Введите временный пароль" />
                    <span asp-validation-for="Password" class="app-validation"></span>
                </div>
            </div>

            <div class="flex flex-col gap-3 pt-4 sm:flex-row sm:items-center">
                <button type="submit" class="app-button app-button-primary min-h-12 rounded-2xl px-5 text-sm font-semibold">
                    Сохранить сотрудника
                </button>
                <a asp-action="Index" class="app-button app-button-ghost min-h-12 rounded-2xl px-5 text-sm font-semibold">
                    Отмена
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
