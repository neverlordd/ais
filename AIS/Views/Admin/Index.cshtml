@model AIS.ViewModels.Admin.AdminIndexViewModel
@{
    ViewData["Title"] = "Панель администратора";

    static string FormatDuration(int totalMinutes)
    {
        var safeMinutes = Math.Max(0, totalMinutes);
        var hours = safeMinutes / 60;
        var minutes = safeMinutes % 60;
        return $"{hours:00}:{minutes:00}";
    }
}

<div class="app-page">
    <section class="app-surface rounded-[2rem] px-5 py-5 sm:px-6 sm:py-6 lg:px-8 lg:py-7">
        <div class="app-section-card">
            <div class="app-toolbar">
                <div>
                    <p class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-slate-400 dark:text-slate-500">Администрирование</p>
                    <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950 dark:text-white">Сотрудники</h1>
                </div>

                <div class="flex flex-wrap items-center gap-3">
                    <a asp-action="Create" class="app-button app-button-primary min-h-12 rounded-[1.25rem] px-5 text-sm font-semibold">
                        Добавить сотрудника
                    </a>
                </div>
            </div>

            <div class="app-meta-row text-sm text-slate-500 dark:text-slate-400">
                <span class="app-inline-meta-pill">Всего: @Model.TotalEmployees</span>
                <span class="app-inline-meta-pill">На смене: @Model.ActiveEmployees</span>
                <span class="app-inline-meta-pill">Показано: @Model.FilteredEmployeesCount</span>
                @if (Model.LongRunningShiftsCount > 0)
                {
                    <span class="app-inline-meta-pill">Требуют внимания: @Model.LongRunningShiftsCount</span>
                }
            </div>

            <form method="get" class="grid gap-3 lg:grid-cols-[minmax(0,1fr)_14rem_auto] lg:items-end">
                <div class="app-field">
                    <label for="search" class="app-label">Поиск</label>
                    <input id="search" name="search" value="@Model.SearchQuery" class="app-input" placeholder="ФИО или логин" />
                </div>

                <div class="app-field">
                    <label for="status" class="app-label">Фильтр</label>
                    <select id="status" name="status" class="app-select">
                        <option value="@AIS.ViewModels.Admin.AdminStatusFilterOption.All" selected="@(Model.StatusFilter == AIS.ViewModels.Admin.AdminStatusFilterOption.All)">Все сотрудники</option>
                        <option value="@AIS.ViewModels.Admin.AdminStatusFilterOption.OnShift" selected="@(Model.StatusFilter == AIS.ViewModels.Admin.AdminStatusFilterOption.OnShift)">На смене</option>
                        <option value="@AIS.ViewModels.Admin.AdminStatusFilterOption.OffShift" selected="@(Model.StatusFilter == AIS.ViewModels.Admin.AdminStatusFilterOption.OffShift)">Вне смены</option>
                        <option value="@AIS.ViewModels.Admin.AdminStatusFilterOption.Admins" selected="@(Model.StatusFilter == AIS.ViewModels.Admin.AdminStatusFilterOption.Admins)">Только администраторы</option>
                    </select>
                </div>

                <div class="flex gap-2">
                    <button type="submit" class="app-button app-button-primary min-h-12 rounded-[1.15rem] px-5 text-sm font-semibold">
                        Применить
                    </button>
                    <a asp-action="Index" class="app-button app-button-ghost min-h-12 rounded-[1.15rem] px-5 text-sm font-semibold">
                        Сбросить
                    </a>
                </div>
            </form>
        </div>
    </section>

    <section class="space-y-4">
        @if (!Model.Employees.Any())
        {
            <div class="app-surface rounded-[2rem] px-5 py-6 sm:px-6">
                <div class="app-empty-state">
                    <p class="app-empty-state-title">Совпадений нет</p>
                    <p class="app-empty-state-text">Попробуйте другой запрос или сбросьте фильтр.</p>
                </div>
            </div>
        }
        else
        {
            <div class="grid gap-6 xl:hidden">
                @foreach (var employee in Model.Employees)
                {
                    <article class="app-surface rounded-[1.75rem] px-5 py-5 sm:px-6">
                        <div class="flex items-start justify-between gap-4">
                            <div class="min-w-0">
                                <h2 class="text-base font-semibold text-slate-950 dark:text-white">@employee.FullName</h2>
                                <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">@employee.Username · @employee.Role.GetDisplayName()</p>
                            </div>

                            <span class="app-status-pill app-status-pill-fixed @(employee.NeedsAttention ? "app-status-pill-warning" : employee.IsOnShift ? "app-status-pill-active" : "app-status-pill-idle")">
                                @(employee.NeedsAttention ? "Долго на смене" : employee.IsOnShift ? "На смене" : "Вне смены")
                            </span>
                        </div>

                        <div class="mt-4 grid gap-3 sm:grid-cols-2">
                            <div class="app-muted-surface app-admin-stat-card rounded-[1.25rem] px-4 py-3">
                                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">Текущая смена</p>
                                @if (employee.IsOnShift && employee.ActiveShiftStartTime.HasValue)
                                {
                                    <p data-shift-timer data-shift-start-unix="@(new DateTimeOffset(employee.ActiveShiftStartTime.Value).ToUnixTimeSeconds())" class="app-admin-metric-primary mt-2 font-mono text-xl font-semibold tracking-tight text-slate-950 dark:text-white">00:00:00</p>
                                    <p class="app-admin-metric-secondary mt-1 text-sm text-slate-500 dark:text-slate-400">С @employee.ActiveShiftStartTime.Value.ToString("HH:mm")</p>
                                }
                                else
                                {
                                    <p class="app-admin-metric-primary mt-2 text-base font-semibold text-slate-400 dark:text-slate-500">—</p>
                                    <p class="app-admin-metric-secondary mt-1 text-sm text-transparent">—</p>
                                }
                            </div>

                            <div class="app-muted-surface app-admin-stat-card rounded-[1.25rem] px-4 py-3">
                                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">Сегодня</p>
                                <p class="app-admin-metric-primary mt-2 text-xl font-semibold tracking-tight text-slate-950 dark:text-white">@FormatDuration(employee.WorkedMinutesToday)</p>
                                <p class="app-admin-metric-secondary mt-1 text-sm text-slate-500 dark:text-slate-400">Отметок: @employee.ShiftsTodayCount</p>
                            </div>
                        </div>

                        <div class="mt-4 flex flex-col gap-3 text-sm sm:flex-row sm:items-center sm:justify-between">
                            <div class="app-admin-last-meta text-slate-500 dark:text-slate-400">
                                Последняя: <span class="font-medium text-slate-900 dark:text-slate-100">@(employee.LastShiftStartTime?.ToString("dd.MM HH:mm") ?? "нет данных")</span>
                            </div>

                            <div class="grid w-full grid-cols-2 gap-2 sm:w-auto sm:grid-cols-[9rem_7rem_7rem]">
                                @if (employee.IsOnShift)
                                {
                                    <form asp-action="EndShift" asp-route-id="@employee.Id" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="app-button app-button-danger app-admin-action-button min-h-10 w-full rounded-[1rem] px-4 text-xs font-semibold">
                                            Завершить
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="StartShift" asp-route-id="@employee.Id" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="app-button app-button-primary app-admin-action-button min-h-10 w-full rounded-[1rem] px-4 text-xs font-semibold">
                                            Начать
                                        </button>
                                    </form>
                                }

                                <a asp-action="Edit" asp-route-id="@employee.Id" class="app-button app-button-ghost app-admin-action-button min-h-10 w-full rounded-[1rem] px-4 text-xs font-semibold">
                                    Изменить
                                </a>
                                <a asp-action="Delete" asp-route-id="@employee.Id" class="app-button app-button-danger-soft app-admin-action-button min-h-10 w-full rounded-[1rem] px-4 text-xs font-semibold">
                                    Удалить
                                </a>
                            </div>
                        </div>
                    </article>
                }
            </div>

            <div class="hidden overflow-hidden rounded-[2rem] xl:block">
                <div class="app-surface overflow-hidden p-0">
                    <div class="app-scrollbar overflow-x-auto">
                        <table class="min-w-full table-fixed">
                            <colgroup>
                                <col class="w-[17%]" />
                                <col class="w-[13%]" />
                                <col class="w-[10%]" />
                                <col class="w-[12%]" />
                                <col class="w-[14%]" />
                                <col class="w-[34%]" />
                            </colgroup>
                            <thead>
                                <tr class="border-b border-slate-200/80 text-left text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-slate-400 dark:border-slate-800 dark:text-slate-500">
                                    <th class="px-6 py-4">Сотрудник</th>
                                    <th class="px-6 py-4">Статус</th>
                                    <th class="px-6 py-4">Сегодня</th>
                                    <th class="px-6 py-4">Текущая смена</th>
                                    <th class="px-6 py-4">Последняя отметка</th>
                                    <th class="px-6 py-4 text-right">Действия</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-200/70 text-sm dark:divide-slate-800">
                                @foreach (var employee in Model.Employees)
                                {
                                    <tr class="app-table-row">
                                        <td class="px-6 py-5 align-middle">
                                            <p class="font-semibold text-slate-950 dark:text-white">@employee.FullName</p>
                                            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">@employee.Username · @employee.Role.GetDisplayName()</p>
                                        </td>
                                        <td class="px-6 py-5 align-middle">
                                            <span class="app-status-pill app-status-pill-fixed @(employee.NeedsAttention ? "app-status-pill-warning" : employee.IsOnShift ? "app-status-pill-active" : "app-status-pill-idle")">
                                                @(employee.NeedsAttention ? "Долго на смене" : employee.IsOnShift ? "На смене" : "Вне смены")
                                            </span>
                                        </td>
                                        <td class="px-6 py-5 align-middle">
                                            <div class="app-admin-cell-stack">
                                                <p class="app-admin-cell-primary font-semibold text-slate-950 dark:text-white">@FormatDuration(employee.WorkedMinutesToday)</p>
                                                <p class="app-admin-cell-secondary mt-1 text-xs text-slate-500 dark:text-slate-400">@employee.ShiftsTodayCount смен</p>
                                            </div>
                                        </td>
                                        <td class="px-6 py-5 align-middle">
                                            <div class="app-admin-cell-stack">
                                            @if (employee.IsOnShift && employee.ActiveShiftStartTime.HasValue)
                                            {
                                                <p data-shift-timer data-shift-start-unix="@(new DateTimeOffset(employee.ActiveShiftStartTime.Value).ToUnixTimeSeconds())" class="app-admin-cell-primary font-mono text-lg font-semibold tracking-tight text-slate-950 dark:text-white">00:00:00</p>
                                                <p class="app-admin-cell-secondary mt-1 text-xs text-slate-500 dark:text-slate-400">С @employee.ActiveShiftStartTime.Value.ToString("HH:mm")</p>
                                            }
                                            else
                                            {
                                                <p class="app-admin-cell-primary text-slate-400 dark:text-slate-500">—</p>
                                                <p class="app-admin-cell-secondary mt-1 text-xs text-transparent">—</p>
                                            }
                                            </div>
                                        </td>
                                        <td class="px-6 py-5 align-middle">
                                            <div class="app-admin-cell-stack">
                                                <p class="app-admin-cell-primary font-medium text-slate-900 dark:text-slate-100">@(employee.LastShiftStartTime?.ToString("dd.MM.yyyy HH:mm") ?? "Нет данных")</p>
                                                <p class="app-admin-cell-secondary mt-1 text-xs text-slate-500 dark:text-slate-400">
                                                    @(employee.LastShiftEndTime.HasValue ? $"Завершена в {employee.LastShiftEndTime.Value:HH:mm}" : employee.IsOnShift ? "Смена активна" : "Окончание не зафиксировано")
                                                </p>
                                            </div>
                                        </td>
                                        <td class="px-6 py-5 align-middle">
                                            <div class="app-admin-actions-grid">
                                                @if (employee.IsOnShift)
                                                {
                                                    <form asp-action="EndShift" asp-route-id="@employee.Id" method="post" class="m-0">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="app-button app-button-danger app-admin-action-button min-h-10 w-full rounded-[1rem] px-4 text-xs font-semibold">
                                                            Завершить
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <form asp-action="StartShift" asp-route-id="@employee.Id" method="post" class="m-0">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="app-button app-button-primary app-admin-action-button min-h-10 w-full rounded-[1rem] px-4 text-xs font-semibold">
                                                            Начать
                                                        </button>
                                                    </form>
                                                }

                                                <a asp-action="Edit" asp-route-id="@employee.Id" class="app-button app-button-ghost app-admin-action-button min-h-10 w-full rounded-[1rem] px-4 text-xs font-semibold">
                                                    Изменить
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@employee.Id" class="app-button app-button-danger-soft app-admin-action-button min-h-10 w-full rounded-[1rem] px-4 text-xs font-semibold">
                                                    Удалить
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </section>
</div>
