@model AIS.ViewModels.Admin.AdminIndexViewModel
@{
    ViewData["Title"] = "Панель администратора";
}

<div class="space-y-6">
    <section class="rounded-[2rem] border border-slate-200/80 bg-white/95 p-5 shadow-soft dark:border-slate-800 dark:bg-slate-900/95 sm:p-6 lg:p-8">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">Администрирование</p>
                <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950 dark:text-white">Сотрудники</h1>
            </div>

            <div class="flex flex-wrap gap-3">
                <div class="rounded-[1.5rem] border border-brand-100 bg-brand-50/80 px-4 py-3 dark:border-brand-900/70 dark:bg-brand-950/30">
                    <p data-live-clock class="font-mono text-xl font-semibold tracking-tight text-slate-950 dark:text-white">00:00:00</p>
                </div>
                <a asp-action="Create" class="inline-flex min-h-12 items-center justify-center rounded-2xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-700 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200">
                    Добавить сотрудника
                </a>
            </div>
        </div>

        <div class="mt-5 grid gap-3 sm:grid-cols-3">
            <div class="rounded-[1.4rem] border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-950/80">
                <p class="text-sm text-slate-500 dark:text-slate-400">Всего</p>
                <p class="mt-1 text-2xl font-semibold text-slate-950 dark:text-white">@Model.TotalEmployees</p>
            </div>
            <div class="rounded-[1.4rem] border border-emerald-200 bg-emerald-50 p-4 dark:border-emerald-950 dark:bg-emerald-950/30">
                <p class="text-sm text-emerald-700 dark:text-emerald-200">На смене</p>
                <p class="mt-1 text-2xl font-semibold text-emerald-800 dark:text-emerald-100">@Model.ActiveEmployees</p>
            </div>
            <div class="rounded-[1.4rem] border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-950/80">
                <p class="text-sm text-slate-500 dark:text-slate-400">Вне смены</p>
                <p class="mt-1 text-2xl font-semibold text-slate-950 dark:text-white">@(Model.TotalEmployees - Model.ActiveEmployees)</p>
            </div>
        </div>
    </section>

    <section class="space-y-4">
        <div class="grid gap-4 lg:hidden">
            @foreach (var employee in Model.Employees)
            {
                <article class="rounded-[1.6rem] border border-slate-200/80 bg-white/95 p-5 shadow-soft dark:border-slate-800 dark:bg-slate-900/95">
                    <div class="flex items-start justify-between gap-4">
                        <div class="min-w-0">
                            <h2 class="text-base font-semibold text-slate-950 dark:text-white">@employee.FullName</h2>
                            <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">@employee.Username • @employee.Role.GetDisplayName()</p>
                        </div>

                        @if (employee.IsOnShift)
                        {
                            <span class="inline-flex shrink-0 items-center rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700 dark:border-emerald-950 dark:bg-emerald-950/50 dark:text-emerald-200">
                                На смене
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex shrink-0 items-center rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-semibold text-slate-600 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-300">
                                Не на смене
                            </span>
                        }
                    </div>

                    <div class="mt-4 grid gap-3 sm:grid-cols-2">
                        <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 dark:border-slate-800 dark:bg-slate-950">
                            <p class="text-xs uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">Таймер</p>
                            @if (employee.IsOnShift && employee.ActiveShiftStartTime.HasValue)
                            {
                                <p data-shift-timer data-shift-start-unix="@(new DateTimeOffset(employee.ActiveShiftStartTime.Value).ToUnixTimeSeconds())" class="mt-2 font-mono text-xl font-semibold text-slate-950 dark:text-white">
                                    00:00:00
                                </p>
                            }
                            else
                            {
                                <p class="mt-2 text-base font-semibold text-slate-400 dark:text-slate-500">—</p>
                            }
                        </div>

                        <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 dark:border-slate-800 dark:bg-slate-950">
                            <p class="text-xs uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">Отметка</p>
                            <p class="mt-2 text-sm font-medium text-slate-700 dark:text-slate-200">
                                @(employee.IsOnShift && employee.ActiveShiftStartTime.HasValue
                                    ? employee.ActiveShiftStartTime.Value.ToString("dd.MM.yyyy HH:mm")
                                    : "Нет активной смены")
                            </p>
                        </div>
                    </div>

                    <div class="mt-4 flex flex-wrap gap-2">
                        @if (employee.IsOnShift)
                        {
                            <form asp-action="EndShift" asp-route-id="@employee.Id" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="inline-flex min-h-11 items-center rounded-2xl bg-rose-600 px-4 text-xs font-semibold text-white transition hover:bg-rose-700">
                                    Завершить
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="StartShift" asp-route-id="@employee.Id" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="inline-flex min-h-11 items-center rounded-2xl bg-slate-900 px-4 text-xs font-semibold text-white transition hover:bg-slate-700 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200">
                                    Начать
                                </button>
                            </form>
                        }

                        <a asp-action="Edit" asp-route-id="@employee.Id" class="inline-flex min-h-11 items-center rounded-2xl border border-slate-200 bg-white px-4 text-xs font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:border-slate-600 dark:hover:text-white">
                            Редактировать
                        </a>
                        <a asp-action="Delete" asp-route-id="@employee.Id" class="inline-flex min-h-11 items-center rounded-2xl border border-rose-200 bg-rose-50 px-4 text-xs font-semibold text-rose-700 transition hover:bg-rose-100 dark:border-rose-950 dark:bg-rose-950/40 dark:text-rose-200 dark:hover:bg-rose-950/70">
                            Удалить
                        </a>
                    </div>
                </article>
            }
        </div>

        <div class="hidden overflow-hidden rounded-[2rem] border border-slate-200/80 bg-white/95 shadow-soft dark:border-slate-800 dark:bg-slate-900/95 lg:block">
            <div class="app-scrollbar overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-800">
                <thead class="bg-slate-50 dark:bg-slate-950/60">
                    <tr class="text-left text-xs font-semibold uppercase tracking-[0.22em] text-slate-500 dark:text-slate-400">
                        <th class="px-6 py-4">Сотрудник</th>
                        <th class="px-6 py-4">Статус</th>
                        <th class="px-6 py-4">Таймер</th>
                        <th class="px-6 py-4">Действие</th>
                        <th class="px-6 py-4 text-right">Управление</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 text-sm dark:divide-slate-800">
                    @foreach (var employee in Model.Employees)
                    {
                        <tr class="align-top">
                            <td class="px-6 py-5">
                                <p class="font-semibold text-slate-950 dark:text-white">@employee.FullName</p>
                                <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">@employee.Username • @employee.Role.GetDisplayName()</p>
                                @if (employee.IsOnShift && employee.ActiveShiftStartTime.HasValue)
                                {
                                    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">@employee.ActiveShiftStartTime.Value.ToString("dd.MM.yyyy HH:mm")</p>
                                }
                            </td>
                            <td class="px-6 py-5">
                                @if (employee.IsOnShift)
                                {
                                    <span class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700 dark:border-emerald-950 dark:bg-emerald-950/50 dark:text-emerald-200">
                                        На смене
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-semibold text-slate-600 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-300">
                                        Не на смене
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-5">
                                @if (employee.IsOnShift && employee.ActiveShiftStartTime.HasValue)
                                {
                                    <p data-shift-timer data-shift-start-unix="@(new DateTimeOffset(employee.ActiveShiftStartTime.Value).ToUnixTimeSeconds())" class="font-mono text-lg font-semibold tracking-tight text-slate-950 dark:text-white">
                                        00:00:00
                                    </p>
                                }
                                else
                                {
                                    <span class="text-sm text-slate-400 dark:text-slate-500">—</span>
                                }
                            </td>
                            <td class="px-6 py-5">
                                @if (employee.IsOnShift)
                                {
                                    <form asp-action="EndShift" asp-route-id="@employee.Id" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="inline-flex items-center rounded-2xl bg-rose-600 px-4 py-2 text-xs font-semibold text-white transition hover:bg-rose-700">
                                            Завершить
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="StartShift" asp-route-id="@employee.Id" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="inline-flex items-center rounded-2xl bg-slate-900 px-4 py-2 text-xs font-semibold text-white transition hover:bg-slate-700 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200">
                                            Начать
                                        </button>
                                    </form>
                                }
                            </td>
                            <td class="px-6 py-5">
                                <div class="flex flex-wrap justify-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@employee.Id" class="inline-flex items-center rounded-2xl border border-slate-200 bg-white px-4 py-2 text-xs font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-200 dark:hover:border-slate-600 dark:hover:text-white">
                                        Редактировать
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@employee.Id" class="inline-flex items-center rounded-2xl border border-rose-200 bg-rose-50 px-4 py-2 text-xs font-semibold text-rose-700 transition hover:bg-rose-100 dark:border-rose-950 dark:bg-rose-950/40 dark:text-rose-200 dark:hover:bg-rose-950/70">
                                        Удалить
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
    </section>
</div>
