@model AIS.ViewModels.Admin.AdminSettingsViewModel
@{
    ViewData["Title"] = "Настройки администратора";
}

<div class="mx-auto max-w-3xl">
    <section class="rounded-[2rem] border border-slate-200/80 bg-white/95 p-5 shadow-soft dark:border-slate-800 dark:bg-slate-900/95 sm:p-6 lg:p-8">
        <div class="border-b border-slate-200 pb-5 dark:border-slate-800">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">Настройки</p>
            <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950 dark:text-white">Админ-аккаунт</h1>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">Измените логин и пароль текущего администратора.</p>
        </div>

        <form asp-action="Settings" method="post" class="mt-6 space-y-5">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700 dark:border-rose-950 dark:bg-rose-950/60 dark:text-rose-200"></div>

            <div class="space-y-2">
                <label asp-for="Username" class="text-sm font-medium text-slate-700 dark:text-slate-200"></label>
                <input asp-for="Username" class="w-full rounded-2xl border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm transition focus:border-brand-500 focus:ring-brand-500 dark:border-slate-700 dark:bg-slate-950 dark:text-white" />
                <span asp-validation-for="Username" class="text-sm text-rose-600 dark:text-rose-300"></span>
            </div>

            <div class="grid gap-5 md:grid-cols-2">
                <div class="space-y-2">
                    <label asp-for="Password" class="text-sm font-medium text-slate-700 dark:text-slate-200"></label>
                    <input asp-for="Password" class="w-full rounded-2xl border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm transition focus:border-brand-500 focus:ring-brand-500 dark:border-slate-700 dark:bg-slate-950 dark:text-white" placeholder="Оставьте пустым, если не меняете" />
                    <span asp-validation-for="Password" class="text-sm text-rose-600 dark:text-rose-300"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="ConfirmPassword" class="text-sm font-medium text-slate-700 dark:text-slate-200"></label>
                    <input asp-for="ConfirmPassword" class="w-full rounded-2xl border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm transition focus:border-brand-500 focus:ring-brand-500 dark:border-slate-700 dark:bg-slate-950 dark:text-white" placeholder="Повторите новый пароль" />
                    <span asp-validation-for="ConfirmPassword" class="text-sm text-rose-600 dark:text-rose-300"></span>
                </div>
            </div>

            <div class="flex flex-wrap gap-3 pt-2">
                <button type="submit" class="inline-flex min-h-12 items-center justify-center rounded-2xl bg-slate-900 px-5 text-sm font-semibold text-white transition hover:bg-slate-700 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200">
                    Сохранить
                </button>
                <a asp-action="Index" class="inline-flex min-h-12 items-center justify-center rounded-2xl border border-slate-200 bg-white px-5 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:border-slate-600 dark:hover:text-white">
                    Назад
                </a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
