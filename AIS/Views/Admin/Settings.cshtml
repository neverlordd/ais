@model AIS.ViewModels.Admin.AdminSettingsViewModel
@{
    ViewData["Title"] = "Настройки администратора";
}

<div class="mx-auto max-w-4xl">
    <section class="app-form-card p-5 sm:p-6 lg:p-8">
        <div class="app-section-header border-b border-slate-200 pb-5 dark:border-slate-800">
            <p class="app-section-kicker">Настройки</p>
            <h1 class="app-section-title">Админ-аккаунт</h1>
            <p class="app-section-description">Измените логин и пароль текущего администратора.</p>
        </div>

        <form asp-action="Settings" method="post" class="mt-6 space-y-5">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="app-validation-summary"></div>

            <div class="app-field">
                <label asp-for="Username" class="app-label"></label>
                <input asp-for="Username" class="app-input" />
                <span asp-validation-for="Username" class="app-validation"></span>
            </div>

            <div class="grid gap-5 md:grid-cols-2">
                <div class="app-field">
                    <label asp-for="Password" class="app-label"></label>
                    <input asp-for="Password" class="app-input" placeholder="Оставьте пустым, если не меняете" />
                    <span asp-validation-for="Password" class="app-validation"></span>
                </div>

                <div class="app-field">
                    <label asp-for="ConfirmPassword" class="app-label"></label>
                    <input asp-for="ConfirmPassword" class="app-input" placeholder="Повторите новый пароль" />
                    <span asp-validation-for="ConfirmPassword" class="app-validation"></span>
                </div>
            </div>

            <div class="flex flex-wrap gap-3 pt-2">
                <button type="submit" class="app-button app-button-primary min-h-12 rounded-2xl px-5 text-sm font-semibold">
                    Сохранить
                </button>
                <a asp-action="Index" class="app-button app-button-ghost min-h-12 rounded-2xl px-5 text-sm font-semibold">
                    Назад
                </a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
