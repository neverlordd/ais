@model AIS.ViewModels.Admin.AdminShiftLogViewModel
@{
    ViewData["Title"] = "Журнал смен";

    static string FormatDuration(int totalMinutes)
    {
        var safeMinutes = Math.Max(0, totalMinutes);
        var hours = safeMinutes / 60;
        var minutes = safeMinutes % 60;
        return $"{hours:00}:{minutes:00}";
    }
}

<div class="app-page">
    <section class="app-surface rounded-[2rem] px-5 py-5 sm:px-6 sm:py-6 lg:px-8 lg:py-7">
        <div class="app-toolbar">
            <div>
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-slate-400 dark:text-slate-500">Журнал</p>
                <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950 dark:text-white">История смен</h1>
            </div>
        </div>

        <div class="app-meta-row mt-5 text-sm text-slate-500 dark:text-slate-400">
            <span class="app-inline-meta-pill">@Model.RangeLabel</span>
            <span class="app-inline-meta-pill">Записей: @Model.TotalRecords</span>
            <span class="app-inline-meta-pill">Сотрудников: @Model.EmployeesInScope</span>
            <span class="app-inline-meta-pill">Время: @FormatDuration(Model.TotalWorkedMinutes)</span>
            @if (Model.ActiveRecords > 0)
            {
                <span class="app-inline-meta-pill">Активных: @Model.ActiveRecords</span>
            }
        </div>
    </section>

    <section class="app-surface rounded-[2rem] px-5 py-5 sm:px-6 sm:py-6 lg:px-8">
        <div class="app-section-card">
            <div>
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-slate-400 dark:text-slate-500">Фильтры и выгрузка</p>
                <h2 class="mt-1 text-xl font-semibold tracking-tight text-slate-950 dark:text-white">Сформировать отчет</h2>
            </div>

            <form method="get" class="grid gap-3 xl:grid-cols-[minmax(0,1fr)_11rem_11rem_13rem_auto] xl:items-end">
                <div class="app-field">
                    <label for="search" class="app-label">Поиск</label>
                    <input id="search" name="search" value="@Model.SearchQuery" class="app-input" placeholder="ФИО или логин" />
                </div>

                <div class="app-field">
                    <label for="period" class="app-label">Период</label>
                    <select id="period" name="period" class="app-select">
                        <option value="today" selected="@(Model.Period == "today")">Сегодня</option>
                        <option value="week" selected="@(Model.Period == "week")">7 дней</option>
                        <option value="month" selected="@(Model.Period == "month")">Месяц</option>
                        <option value="all" selected="@(Model.Period == "all")">Все время</option>
                    </select>
                </div>

                <div class="app-field">
                    <label for="date" class="app-label">Точная дата</label>
                    <input id="date" name="date" type="date" value="@Model.ExactDate" class="app-input" />
                </div>

                <div class="app-field">
                    <label for="attendance" class="app-label">Сотрудники</label>
                    <select id="attendance" name="attendance" class="app-select">
                        <option value="@AIS.ViewModels.Admin.AdminAttendanceFilterOption.All" selected="@(Model.AttendanceFilter == AIS.ViewModels.Admin.AdminAttendanceFilterOption.All)">Все</option>
                        <option value="@AIS.ViewModels.Admin.AdminAttendanceFilterOption.Worked" selected="@(Model.AttendanceFilter == AIS.ViewModels.Admin.AdminAttendanceFilterOption.Worked)">Были на смене</option>
                        <option value="@AIS.ViewModels.Admin.AdminAttendanceFilterOption.Absent" selected="@(Model.AttendanceFilter == AIS.ViewModels.Admin.AdminAttendanceFilterOption.Absent)">Не были на смене</option>
                    </select>
                </div>

                <div class="flex gap-2">
                    <button type="submit" class="app-button app-button-primary min-h-12 rounded-[1.15rem] px-5 text-sm font-semibold">Применить</button>
                    <a href="/admin/shift-log" class="app-button app-button-ghost min-h-12 rounded-[1.15rem] px-5 text-sm font-semibold">Сбросить</a>
                </div>
            </form>

            <div class="app-stat-grid">
                <div class="app-stat-card">
                    <p class="app-stat-label">Всего в выборке</p>
                    <p class="app-stat-value">@Model.EmployeesInScope</p>
                    <p class="app-stat-note">После поиска и фильтра по присутствию</p>
                </div>
                <div class="app-stat-card">
                    <p class="app-stat-label">Были на смене</p>
                    <p class="app-stat-value">@Model.EmployeesWorkedCount</p>
                    <p class="app-stat-note">Есть хотя бы одна запись за период</p>
                </div>
                <div class="app-stat-card">
                    <p class="app-stat-label">Не были на смене</p>
                    <p class="app-stat-value">@Model.EmployeesAbsentCount</p>
                    <p class="app-stat-note">Нет ни одной записи за период</p>
                </div>
            </div>

            <div class="app-actions-row">
                <a asp-action="ShiftLogExport" asp-route-search="@Model.SearchQuery" asp-route-period="@Model.Period" asp-route-date="@Model.ExactDate" asp-route-attendance="@Model.AttendanceFilter" asp-route-mode="rows" class="app-button app-button-ghost min-h-11 rounded-[1rem] px-4 text-sm font-semibold">
                    Журнал CSV
                </a>
                <a asp-action="ShiftLogExport" asp-route-search="@Model.SearchQuery" asp-route-period="@Model.Period" asp-route-date="@Model.ExactDate" asp-route-attendance="@AIS.ViewModels.Admin.AdminAttendanceFilterOption.All" asp-route-mode="employees" class="app-button app-button-ghost min-h-11 rounded-[1rem] px-4 text-sm font-semibold">
                    Все сотрудники CSV
                </a>
                <a asp-action="ShiftLogExport" asp-route-search="@Model.SearchQuery" asp-route-period="@Model.Period" asp-route-date="@Model.ExactDate" asp-route-attendance="@AIS.ViewModels.Admin.AdminAttendanceFilterOption.Worked" asp-route-mode="employees" class="app-button app-button-ghost min-h-11 rounded-[1rem] px-4 text-sm font-semibold">
                    Были на смене CSV
                </a>
                <a asp-action="ShiftLogExport" asp-route-search="@Model.SearchQuery" asp-route-period="@Model.Period" asp-route-date="@Model.ExactDate" asp-route-attendance="@AIS.ViewModels.Admin.AdminAttendanceFilterOption.Absent" asp-route-mode="employees" class="app-button app-button-ghost min-h-11 rounded-[1rem] px-4 text-sm font-semibold">
                    Не были на смене CSV
                </a>
            </div>
        </div>
    </section>

    <section class="app-surface rounded-[2rem] px-5 py-5 sm:px-6 sm:py-6 lg:px-8">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-slate-400 dark:text-slate-500">Сотрудники за период</p>
                <h2 class="mt-1 text-xl font-semibold tracking-tight text-slate-950 dark:text-white">Список сотрудников</h2>
            </div>
            <p class="text-sm text-slate-500 dark:text-slate-400">Текущая выборка без перехода к карточке сотрудника</p>
        </div>

        @if (!Model.Employees.Any())
        {
            <div class="app-empty-state mt-5">
                <p class="app-empty-state-title">Сотрудников нет</p>
                <p class="app-empty-state-text">Измените период, дату или строку поиска.</p>
            </div>
        }
        else
        {
            <div class="mt-5 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
                @foreach (var employee in Model.Employees)
                {
                    <article class="app-muted-surface rounded-[1.35rem] px-4 py-4">
                        <div class="flex items-start justify-between gap-3">
                            <div class="min-w-0">
                                <p class="truncate font-semibold text-slate-950 dark:text-white">@employee.FullName</p>
                                <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">@employee.Username</p>
                            </div>
                            <span class="app-status-pill @(employee.WasOnShiftInPeriod ? (employee.HasActiveShift ? "app-status-pill-active" : "app-status-pill-idle") : "app-status-pill-warning")">
                                @(employee.WasOnShiftInPeriod ? $"{employee.ShiftsCount} смен" : "Без смен")
                            </span>
                        </div>

                        <div class="mt-4 flex items-center justify-between gap-3">
                            <div>
                                <p class="text-sm text-slate-500 dark:text-slate-400">Время</p>
                                <p class="mt-1 text-lg font-semibold text-slate-950 dark:text-white">@FormatDuration(employee.WorkedMinutes)</p>
                            </div>
                            <div class="text-right">
                                <p class="text-sm text-slate-500 dark:text-slate-400">Первый вход</p>
                                <p class="mt-1 font-medium text-slate-950 dark:text-white">@(employee.FirstStartTime?.ToString("HH:mm") ?? "—")</p>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <section class="app-surface overflow-hidden rounded-[2rem] px-5 py-5 sm:px-6 sm:py-6 lg:px-8">
        <div class="mb-5 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-slate-400 dark:text-slate-500">Журнал смен</p>
                <h2 class="mt-1 text-xl font-semibold tracking-tight text-slate-950 dark:text-white">События по отметкам</h2>
            </div>
            <p class="text-sm text-slate-500 dark:text-slate-400">Показываются только реальные записи о сменах</p>
        </div>

        @if (!Model.Rows.Any())
        {
            <div class="app-empty-state">
                <p class="app-empty-state-title">Записей нет</p>
                <p class="app-empty-state-text">Для текущего набора условий журнал пуст. Если нужен список сотрудников без смен, используйте карточки выше или CSV-выгрузку.</p>
            </div>
        }
        else
        {
            <div class="overflow-hidden rounded-[1.5rem] bg-slate-50/80 dark:bg-slate-950/50">
                <div class="app-scrollbar overflow-x-auto">
                    <table class="min-w-full">
                        <thead>
                            <tr class="border-b border-slate-200/70 text-left text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-slate-400 dark:border-slate-800 dark:text-slate-500">
                                <th class="px-4 py-3 sm:px-5">Сотрудник</th>
                                <th class="px-4 py-3 sm:px-5">Старт</th>
                                <th class="px-4 py-3 sm:px-5">Финиш</th>
                                <th class="px-4 py-3 sm:px-5">Статус</th>
                                <th class="px-4 py-3 text-right sm:px-5">Длительность</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200/70 text-sm dark:divide-slate-800">
                            @foreach (var row in Model.Rows)
                            {
                                <tr class="app-table-row">
                                    <td class="px-4 py-4 sm:px-5">
                                        <p class="font-medium text-slate-950 dark:text-white">@row.FullName</p>
                                        <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">@row.Username · @row.Role.GetDisplayName()</p>
                                    </td>
                                    <td class="px-4 py-4 text-slate-600 dark:text-slate-300 sm:px-5">@row.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td class="px-4 py-4 text-slate-600 dark:text-slate-300 sm:px-5">@(row.EndTime?.ToString("dd.MM.yyyy HH:mm") ?? "В работе")</td>
                                    <td class="px-4 py-4 sm:px-5">
                                        <span class="app-status-pill @(row.IsActive ? "app-status-pill-active" : "app-status-pill-idle")">
                                            @(row.IsActive ? "Активна" : "Завершена")
                                        </span>
                                    </td>
                                    <td class="px-4 py-4 text-right font-medium text-slate-950 dark:text-white sm:px-5">@FormatDuration(row.DurationMinutes)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </section>
</div>
