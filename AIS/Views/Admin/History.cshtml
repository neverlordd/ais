@model AIS.ViewModels.Admin.AdminShiftLogViewModel
@{
    ViewData["Title"] = "Журнал смен";

    static string FormatDuration(int totalMinutes)
    {
        var safeMinutes = Math.Max(0, totalMinutes);
        var hours = safeMinutes / 60;
        var minutes = safeMinutes % 60;
        return $"{hours:00}:{minutes:00}";
    }
}

<div class="app-page">
    <section class="app-surface rounded-[2rem] px-5 py-5 sm:px-6 sm:py-6 lg:px-8 lg:py-7">
        <div class="app-toolbar">
            <div>
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-slate-400 dark:text-slate-500">Отчет</p>
                <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950 dark:text-white">Сотрудники за период</h1>
            </div>
        </div>
    </section>

    <section class="app-surface rounded-[2rem] px-5 py-5 sm:px-6 sm:py-6 lg:px-8">
        <div class="app-section-card">
            <div>
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-slate-400 dark:text-slate-500">Период и выгрузка</p>
                <h2 class="mt-1 text-xl font-semibold tracking-tight text-slate-950 dark:text-white">Выберите параметры отчета</h2>
            </div>

            <form method="get" class="grid gap-3 xl:grid-cols-[12rem_12rem_14rem_auto] xl:items-end">
                <div class="app-field">
                    <label for="period" class="app-label">Период</label>
                    <select id="period" name="period" class="app-select">
                        <option value="today" selected="@(Model.Period == "today")">Сегодня</option>
                        <option value="week" selected="@(Model.Period == "week")">7 дней</option>
                        <option value="month" selected="@(Model.Period == "month")">Месяц</option>
                        <option value="all" selected="@(Model.Period == "all")">Все время</option>
                    </select>
                </div>

                <div class="app-field">
                    <label for="date" class="app-label">Точная дата</label>
                    <input id="date" name="date" type="date" value="@Model.ExactDate" class="app-input" />
                </div>

                <div class="app-field">
                    <label for="attendance" class="app-label">Сотрудники</label>
                    <select id="attendance" name="attendance" class="app-select">
                        <option value="@AIS.ViewModels.Admin.AdminAttendanceFilterOption.All" selected="@(Model.AttendanceFilter == AIS.ViewModels.Admin.AdminAttendanceFilterOption.All)">Все</option>
                        <option value="@AIS.ViewModels.Admin.AdminAttendanceFilterOption.Worked" selected="@(Model.AttendanceFilter == AIS.ViewModels.Admin.AdminAttendanceFilterOption.Worked)">Были на смене</option>
                        <option value="@AIS.ViewModels.Admin.AdminAttendanceFilterOption.Absent" selected="@(Model.AttendanceFilter == AIS.ViewModels.Admin.AdminAttendanceFilterOption.Absent)">Не были на смене</option>
                    </select>
                </div>

                <div class="flex gap-2">
                    <button type="submit" class="app-button app-button-primary min-h-12 rounded-[1.15rem] px-5 text-sm font-semibold">Показать</button>
                    <a href="/admin/shift-log" class="app-button app-button-ghost min-h-12 rounded-[1.15rem] px-5 text-sm font-semibold">Сбросить</a>
                </div>
            </form>

            <div class="app-meta-row text-sm text-slate-500 dark:text-slate-400">
                <span class="app-inline-meta-pill">@Model.RangeLabel</span>
                <span class="app-inline-meta-pill">Всего: @Model.EmployeesMatchedCount</span>
                <span class="app-inline-meta-pill">Показано: @Model.EmployeesInScope</span>
                <span class="app-inline-meta-pill">Были: @Model.EmployeesWorkedCount</span>
                <span class="app-inline-meta-pill">Не были: @Model.EmployeesAbsentCount</span>
            </div>

            <div class="app-actions-row">
                <a asp-action="ShiftLogExport" asp-route-period="@Model.Period" asp-route-date="@Model.ExactDate" asp-route-attendance="@Model.AttendanceFilter" asp-route-mode="employees" class="app-button app-button-primary min-h-11 rounded-[1rem] px-4 text-sm font-semibold">
                    Скачать список CSV
                </a>
            </div>
        </div>
    </section>

    <section class="app-surface overflow-hidden rounded-[2rem] px-5 py-5 sm:px-6 sm:py-6 lg:px-8">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-slate-400 dark:text-slate-500">Результат</p>
                <h2 class="mt-1 text-xl font-semibold tracking-tight text-slate-950 dark:text-white">Список сотрудников</h2>
            </div>
            <p class="text-sm text-slate-500 dark:text-slate-400">Текущая выборка по выбранному периоду</p>
        </div>

        @if (!Model.Employees.Any())
        {
            <div class="app-empty-state mt-5">
                <p class="app-empty-state-title">Сотрудников нет</p>
                <p class="app-empty-state-text">Измените период, дату или фильтр присутствия.</p>
            </div>
        }
        else
        {
            <div class="overflow-hidden rounded-[1.5rem] bg-slate-50/80 dark:bg-slate-950/50">
                <div class="app-scrollbar overflow-x-auto">
                    <table class="min-w-full">
                        <thead>
                            <tr class="border-b border-slate-200/70 text-left text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-slate-400 dark:border-slate-800 dark:text-slate-500">
                                <th class="px-4 py-3 sm:px-5">Сотрудник</th>
                                <th class="px-4 py-3 sm:px-5">Логин</th>
                                <th class="px-4 py-3 sm:px-5">Статус</th>
                                <th class="px-4 py-3 sm:px-5">Смен</th>
                                <th class="px-4 py-3 sm:px-5">Первый вход</th>
                                <th class="px-4 py-3 text-right sm:px-5">Длительность</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200/70 text-sm dark:divide-slate-800">
                            @foreach (var employee in Model.Employees)
                            {
                                <tr class="app-table-row">
                                    <td class="px-4 py-4 font-medium text-slate-950 dark:text-white sm:px-5">@employee.FullName</td>
                                    <td class="px-4 py-4 text-slate-600 dark:text-slate-300 sm:px-5">@employee.Username</td>
                                    <td class="px-4 py-4 sm:px-5">
                                        <span class="app-status-pill @(employee.WasOnShiftInPeriod ? "app-status-pill-active" : "app-status-pill-idle")">
                                            @(employee.WasOnShiftInPeriod ? "Был на смене" : "Не был на смене")
                                        </span>
                                    </td>
                                    <td class="px-4 py-4 text-slate-600 dark:text-slate-300 sm:px-5">@employee.ShiftsCount</td>
                                    <td class="px-4 py-4 text-slate-600 dark:text-slate-300 sm:px-5">@(employee.FirstStartTime?.ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
                                    <td class="px-4 py-4 text-right font-medium text-slate-950 dark:text-white sm:px-5">@FormatDuration(employee.WorkedMinutes)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </section>
</div>
