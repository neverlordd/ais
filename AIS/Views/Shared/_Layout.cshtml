@{
    var title = ViewData["Title"]?.ToString();
    var pageTitle = string.IsNullOrWhiteSpace(title) ? "ShiftLine" : $"{title} | ShiftLine";

    var statusMessage = TempData["StatusMessage"]?.ToString();
    var statusType = TempData["StatusType"]?.ToString() ?? "success";

    var alertClass = statusType switch
    {
        "error" => "border-rose-200 bg-rose-50/95 text-rose-700 dark:border-rose-950 dark:bg-rose-950/60 dark:text-rose-200",
        "warning" => "border-amber-200 bg-amber-50/95 text-amber-700 dark:border-amber-950 dark:bg-amber-950/60 dark:text-amber-200",
        _ => "border-emerald-200 bg-emerald-50/95 text-emerald-700 dark:border-emerald-950 dark:bg-emerald-950/60 dark:text-emerald-200"
    };

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isHome = currentController == "Home" && currentAction == "Index";
    var isAdmin = currentController == "Admin" && currentAction == "Index";
    var isAdminSettings = currentController == "Admin" && currentAction == "Settings";
    var isFaq = currentController == "Home" && currentAction == "Faq";
}
<!DOCTYPE html>
<html lang="ru" class="h-full bg-slate-50">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script>
        tailwind = {
            config: {
                darkMode: "class",
                theme: {
                    extend: {
                        colors: {
                            brand: {
                                50: "#eff6ff",
                                100: "#dbeafe",
                                500: "#2563eb",
                                600: "#1d4ed8"
                            }
                        },
                        fontFamily: {
                            sans: ["IBM Plex Sans", "system-ui", "sans-serif"]
                        },
                        boxShadow: {
                            soft: "0 20px 50px rgba(15, 23, 42, 0.08)"
                        }
                    }
                }
            }
        };
    </script>
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <script>
        (function () {
            var root = document.documentElement;
            root.classList.remove("dark");
            root.dataset.themeReady = "true";
            root.dataset.theme = "light";
        })();
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-full bg-slate-50 text-slate-900 antialiased dark:bg-slate-950 dark:text-slate-100">
    <div class="min-h-screen bg-[radial-gradient(circle_at_top_right,_rgba(37,99,235,0.08),_transparent_24%),linear-gradient(to_bottom,_rgba(255,255,255,0.98),_rgba(248,250,252,1))] dark:bg-[radial-gradient(circle_at_top_right,_rgba(59,130,246,0.12),_transparent_24%),linear-gradient(to_bottom,_rgba(2,6,23,0.98),_rgba(2,6,23,1))]">
        <header class="sticky top-0 z-30 border-b border-slate-200/80 bg-white/90 backdrop-blur-xl dark:border-slate-800 dark:bg-slate-950/90">
            <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between gap-4">
                    <div class="flex min-w-0 items-center gap-3">
                        <a asp-controller="Home" asp-action="Index" class="flex h-11 w-11 items-center justify-center rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900" aria-label="ShiftLine">
                            <span class="flex items-end gap-1">
                                <span class="h-3 w-1.5 rounded-full bg-slate-400 dark:bg-slate-500"></span>
                                <span class="h-5 w-1.5 rounded-full bg-slate-900 dark:bg-white"></span>
                                <span class="h-7 w-1.5 rounded-full bg-brand-500"></span>
                            </span>
                        </a>
                        <div class="min-w-0">
                            <a asp-controller="Home" asp-action="Index" class="block text-lg font-semibold tracking-tight text-slate-950 dark:text-white">ShiftLine</a>
                            <p class="text-xs uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">@DateTime.Now.ToString("dd MMMM yyyy")</p>
                        </div>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="hidden lg:flex lg:items-center lg:gap-2">
                            <nav class="flex flex-wrap items-center gap-2">
                                <a asp-controller="Home" asp-action="Index" class="inline-flex min-h-11 items-center rounded-2xl px-4 text-sm font-medium transition @(isHome ? "bg-slate-900 text-white dark:bg-white dark:text-slate-900" : "border border-slate-200 bg-white text-slate-700 hover:border-slate-300 hover:text-slate-950 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:border-slate-600 dark:hover:text-white")">
                                    Главная
                                </a>
                                @if (User.IsInRole(nameof(UserRole.Admin)))
                                {
                                    <a asp-controller="Admin" asp-action="Index" class="inline-flex min-h-11 items-center rounded-2xl px-4 text-sm font-medium transition @(isAdmin ? "bg-slate-900 text-white dark:bg-white dark:text-slate-900" : "border border-slate-200 bg-white text-slate-700 hover:border-slate-300 hover:text-slate-950 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:border-slate-600 dark:hover:text-white")">
                                        Сотрудники
                                    </a>
                                    <a asp-controller="Admin" asp-action="Settings" class="inline-flex min-h-11 items-center rounded-2xl px-4 text-sm font-medium transition @(isAdminSettings ? "bg-slate-900 text-white dark:bg-white dark:text-slate-900" : "border border-slate-200 bg-white text-slate-700 hover:border-slate-300 hover:text-slate-950 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:border-slate-600 dark:hover:text-white")">
                                        Настройки
                                    </a>
                                }
                                <a asp-controller="Home" asp-action="Faq" class="inline-flex min-h-11 items-center rounded-2xl px-4 text-sm font-medium transition @(isFaq ? "bg-slate-900 text-white dark:bg-white dark:text-slate-900" : "border border-slate-200 bg-white text-slate-700 hover:border-slate-300 hover:text-slate-950 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:border-slate-600 dark:hover:text-white")">
                                    FAQ
                                </a>
                            </nav>

                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="inline-flex min-h-11 items-center rounded-2xl bg-slate-900 px-4 text-sm font-semibold text-white transition hover:bg-slate-700 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200">
                                    Выйти
                                </button>
                            </form>
                        </div>

                        <button id="mobile-menu-toggle" type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-slate-200 bg-white text-slate-700 transition hover:border-slate-300 hover:text-slate-950 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:border-slate-600 dark:hover:text-white lg:hidden" aria-expanded="false" aria-controls="mobile-menu" aria-label="Открыть меню">
                            <span class="text-lg" data-menu-icon>☰</span>
                        </button>
                    }
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div id="mobile-menu" class="hidden pt-4 lg:hidden">
                        <div class="space-y-2 rounded-[1.75rem] border border-slate-200 bg-white p-3 shadow-soft dark:border-slate-800 dark:bg-slate-900">
                            <a asp-controller="Home" asp-action="Index" class="flex min-h-11 items-center rounded-2xl px-4 text-sm font-medium transition @(isHome ? "bg-slate-900 text-white dark:bg-white dark:text-slate-900" : "text-slate-700 hover:bg-slate-50 hover:text-slate-950 dark:text-slate-200 dark:hover:bg-slate-800 dark:hover:text-white")">
                                Главная
                            </a>
                            @if (User.IsInRole(nameof(UserRole.Admin)))
                            {
                                <a asp-controller="Admin" asp-action="Index" class="flex min-h-11 items-center rounded-2xl px-4 text-sm font-medium transition @(isAdmin ? "bg-slate-900 text-white dark:bg-white dark:text-slate-900" : "text-slate-700 hover:bg-slate-50 hover:text-slate-950 dark:text-slate-200 dark:hover:bg-slate-800 dark:hover:text-white")">
                                    Сотрудники
                                </a>
                                <a asp-controller="Admin" asp-action="Settings" class="flex min-h-11 items-center rounded-2xl px-4 text-sm font-medium transition @(isAdminSettings ? "bg-slate-900 text-white dark:bg-white dark:text-slate-900" : "text-slate-700 hover:bg-slate-50 hover:text-slate-950 dark:text-slate-200 dark:hover:bg-slate-800 dark:hover:text-white")">
                                    Настройки
                                </a>
                            }
                            <a asp-controller="Home" asp-action="Faq" class="flex min-h-11 items-center rounded-2xl px-4 text-sm font-medium transition @(isFaq ? "bg-slate-900 text-white dark:bg-white dark:text-slate-900" : "text-slate-700 hover:bg-slate-50 hover:text-slate-950 dark:text-slate-200 dark:hover:bg-slate-800 dark:hover:text-white")">
                                FAQ
                            </a>

                            <div class="border-t border-slate-200 pt-2 dark:border-slate-800">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="flex min-h-11 w-full items-center rounded-2xl px-4 text-sm font-semibold text-rose-700 transition hover:bg-rose-50 dark:text-rose-300 dark:hover:bg-rose-950/40">
                                        Выйти
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </header>

        <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <div data-alert class="mb-6 transform rounded-2xl border px-5 py-4 text-sm font-medium shadow-soft transition duration-300 @alertClass">
                    @statusMessage
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
