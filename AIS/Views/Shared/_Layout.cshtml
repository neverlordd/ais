@{
    var title = ViewData["Title"]?.ToString();
    var pageTitle = string.IsNullOrWhiteSpace(title) ? "ShiftLine" : $"{title} | ShiftLine";

    var statusMessage = TempData["StatusMessage"]?.ToString();
    var statusType = TempData["StatusType"]?.ToString() ?? "success";

    var alertClass = statusType switch
    {
        "error" => "border-rose-200 bg-rose-50/95 text-rose-700 dark:border-rose-950 dark:bg-rose-950/60 dark:text-rose-200",
        "warning" => "border-amber-200 bg-amber-50/95 text-amber-700 dark:border-amber-950 dark:bg-amber-950/60 dark:text-amber-200",
        _ => "border-emerald-200 bg-emerald-50/95 text-emerald-700 dark:border-emerald-950 dark:bg-emerald-950/60 dark:text-emerald-200"
    };

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isHome = currentController == "Home" && currentAction == "Index";
    var isHistory = currentController == "Home" && currentAction == "Shifts";
    var isAdmin = currentController == "Admin" && currentAction == "Index";
    var isAdminHistory = currentController == "Admin" && currentAction == "ShiftLog";
    var isAdminSettings = currentController == "Admin" && currentAction == "Settings";
    var isFaq = currentController == "Home" && currentAction == "Faq";
}
<!DOCTYPE html>
<html lang="ru" class="h-full bg-slate-50">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script>
        (function () {
            var root = document.documentElement;
            var theme = "light";

            try {
                var savedTheme = localStorage.getItem("shiftline-theme");
                if (savedTheme === "dark" || savedTheme === "light") {
                    theme = savedTheme;
                }
            } catch (error) {
            }

            root.classList.toggle("dark", theme === "dark");
            root.dataset.theme = theme;
            root.dataset.themeReady = "true";
        })();
    </script>
    <link rel="stylesheet" href="~/css/tailwind.generated.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-full bg-slate-50 text-slate-900 antialiased dark:bg-slate-950 dark:text-slate-100">
    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div id="app-toast-payload" data-toast-message="@statusMessage" data-toast-type="@statusType" hidden></div>
    }

    <div class="app-shell min-h-screen">
        <header class="sticky top-0 z-30">
            <div class="mx-auto max-w-7xl px-4 pt-4 sm:px-6 lg:px-8">
                <div class="app-header-shell rounded-[1.9rem] px-4 py-4 sm:px-5">
                <div class="flex items-center justify-between gap-4">
                    <div class="flex min-w-0 items-center gap-3">
                        <a asp-controller="Home" asp-action="Index" class="app-logo-mark" aria-label="ShiftLine">
                            <span class="flex items-end gap-1">
                                <span class="h-3 w-1.5 rounded-full bg-slate-400 dark:bg-slate-500"></span>
                                <span class="h-5 w-1.5 rounded-full bg-slate-900 dark:bg-white"></span>
                                <span class="h-7 w-1.5 rounded-full bg-brand-500"></span>
                            </span>
                        </a>
                        <div class="min-w-0">
                            <a asp-controller="Home" asp-action="Index" class="block text-lg font-semibold tracking-tight text-slate-950 dark:text-white">ShiftLine</a>
                            <p class="text-xs uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">@DateTime.Now.ToString("dd MMMM yyyy")</p>
                        </div>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="hidden lg:flex lg:min-w-0 lg:flex-1 lg:items-center lg:justify-end lg:gap-3">
                            <nav class="flex min-w-0 flex-wrap items-center gap-1.5">
                                <a asp-controller="Home" asp-action="Index" class="app-nav-link @(isHome ? "app-nav-link-active" : string.Empty)">
                                    Главная
                                </a>
                                <a href="/me/shifts" class="app-nav-link @(isHistory ? "app-nav-link-active" : string.Empty)">
                                    История
                                </a>
                                @if (User.IsInRole(nameof(UserRole.Admin)))
                                {
                                    <a asp-controller="Admin" asp-action="Index" class="app-nav-link @(isAdmin ? "app-nav-link-active" : string.Empty)">
                                        Сотрудники
                                    </a>
                                    <a href="/admin/shift-log" class="app-nav-link @(isAdminHistory ? "app-nav-link-active" : string.Empty)">
                                        Журнал
                                    </a>
                                    <a asp-controller="Admin" asp-action="Settings" class="app-nav-link @(isAdminSettings ? "app-nav-link-active" : string.Empty)">
                                        Настройки
                                    </a>
                                }
                                <a asp-controller="Home" asp-action="Faq" class="app-nav-link @(isFaq ? "app-nav-link-active" : string.Empty)">
                                    FAQ
                                </a>
                            </nav>

                            <div class="flex items-center gap-2">
                                <button id="theme-toggle" type="button" class="inline-flex h-11 w-11 items-center justify-center app-icon-button" aria-label="Сменить тему" title="Сменить тему">
                                    <span class="text-lg leading-none" data-theme-icon>◐</span>
                                </button>

                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="app-button app-logout-button min-h-11 px-2 text-sm font-semibold">
                                        Выйти
                                    </button>
                                </form>
                            </div>
                        </div>

                        <button id="mobile-menu-toggle" type="button" class="inline-flex h-11 w-11 items-center justify-center app-icon-button lg:hidden" aria-expanded="false" aria-controls="mobile-menu" aria-label="Открыть меню">
                            <span class="text-lg" data-menu-icon>☰</span>
                        </button>
                    }
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div id="mobile-menu" class="hidden pt-4 lg:hidden">
                        <div class="app-surface space-y-2 rounded-[1.75rem] p-3">
                            <a asp-controller="Home" asp-action="Index" class="app-mobile-link @(isHome ? "app-mobile-link-active" : string.Empty)">
                                Главная
                            </a>
                            <a href="/me/shifts" class="app-mobile-link @(isHistory ? "app-mobile-link-active" : string.Empty)">
                                История
                            </a>
                            @if (User.IsInRole(nameof(UserRole.Admin)))
                            {
                                <a asp-controller="Admin" asp-action="Index" class="app-mobile-link @(isAdmin ? "app-mobile-link-active" : string.Empty)">
                                    Сотрудники
                                </a>
                                <a href="/admin/shift-log" class="app-mobile-link @(isAdminHistory ? "app-mobile-link-active" : string.Empty)">
                                    Журнал
                                </a>
                                <a asp-controller="Admin" asp-action="Settings" class="app-mobile-link @(isAdminSettings ? "app-mobile-link-active" : string.Empty)">
                                    Настройки
                                </a>
                            }
                            <a asp-controller="Home" asp-action="Faq" class="app-mobile-link @(isFaq ? "app-mobile-link-active" : string.Empty)">
                                FAQ
                            </a>

                            <div class="border-t border-slate-200/70 pt-2 dark:border-slate-800">
                                <button id="theme-toggle-mobile" type="button" class="app-mobile-link w-full justify-start" aria-label="Сменить тему">
                                    <span class="mr-3 text-base leading-none" data-theme-icon-mobile>◐</span>
                                    Тема
                                </button>

                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="app-mobile-link app-mobile-link-logout w-full justify-start">
                                        Выйти
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
                </div>
            </div>
        </header>

        <main class="mx-auto max-w-7xl px-4 py-7 sm:px-6 sm:py-9 lg:px-8">
            @RenderBody()
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
