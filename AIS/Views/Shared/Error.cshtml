@model ErrorViewModel
@{
    ViewData["Title"] = "Ошибка";
}

<div class="mx-auto max-w-2xl rounded-3xl border border-rose-200/70 bg-white/90 p-8 shadow-lg shadow-slate-950/5 dark:border-rose-900/50 dark:bg-slate-900/90">
    <p class="text-sm font-semibold uppercase tracking-[0.24em] text-rose-500">Системное сообщение</p>
    <h1 class="mt-3 text-3xl font-semibold text-slate-900 dark:text-white">Во время обработки запроса произошла ошибка.</h1>
    <p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-300">
        Попробуйте обновить страницу или вернуться на главную панель. Если проблема повторяется, проверьте журналы приложения.
    </p>

    @if (Model.ShowRequestId)
    {
        <div class="mt-6 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600 dark:border-slate-800 dark:bg-slate-950 dark:text-slate-300">
            Идентификатор запроса:
            <code class="font-mono text-slate-900 dark:text-slate-100">@Model.RequestId</code>
        </div>
    }

    <div class="mt-8">
        <a asp-controller="Home" asp-action="Index" class="inline-flex items-center rounded-2xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-700 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200">
            Вернуться на главную
        </a>
    </div>
</div>
