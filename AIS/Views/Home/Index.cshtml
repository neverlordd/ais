@model AIS.ViewModels.Home.DashboardViewModel
@{
    ViewData["Title"] = "Главная";
    var hasCompletedShift = Model.LatestShiftStartTimeToday.HasValue && Model.LatestShiftEndTimeToday.HasValue;
    var stateTitle = Model.HasActiveShift && Model.ActiveShiftStartTime.HasValue
        ? "Смена активна"
        : hasCompletedShift
            ? "Последняя смена сегодня"
            : "Смена";
    var leftLabel = Model.HasActiveShift && Model.ActiveShiftStartTime.HasValue
        ? "Начало"
        : hasCompletedShift
            ? "Приход"
            : "Статус";
    var leftValue = Model.HasActiveShift && Model.ActiveShiftStartTime.HasValue
        ? Model.ActiveShiftStartTime.Value.ToString("HH:mm")
        : hasCompletedShift
            ? Model.LatestShiftStartTimeToday!.Value.ToString("HH:mm")
            : "Ожидание";
    var rightLabel = Model.HasActiveShift && Model.ActiveShiftStartTime.HasValue
        ? "Продолжительность"
        : hasCompletedShift
            ? "Уход"
            : "Готово";
    var rightValue = Model.HasActiveShift && Model.ActiveShiftStartTime.HasValue
        ? null
        : hasCompletedShift
            ? Model.LatestShiftEndTimeToday!.Value.ToString("HH:mm")
            : "—";
    var helperText = Model.HasActiveShift && Model.ActiveShiftStartTime.HasValue
        ? $"Смена началась в {Model.ActiveShiftStartTime.Value:HH:mm}"
        : hasCompletedShift
            ? "Все отметки за сегодня завершены"
            : "Можно начать новую смену";
    var actionLabel = Model.HasActiveShift && Model.ActiveShiftStartTime.HasValue
        ? "Завершить смену"
        : hasCompletedShift
            ? "Начать новую смену"
            : "Начать смену";
    var actionClass = Model.HasActiveShift && Model.ActiveShiftStartTime.HasValue
        ? "app-button app-button-danger min-h-14 w-full justify-center rounded-[1.25rem] px-5 text-sm font-semibold"
        : "app-button app-button-primary min-h-14 w-full justify-center rounded-[1.25rem] px-5 text-sm font-semibold";

    static string FormatDuration(int totalMinutes)
    {
        var safeMinutes = Math.Max(0, totalMinutes);
        var hours = safeMinutes / 60;
        var minutes = safeMinutes % 60;
        return $"{hours:00}:{minutes:00}";
    }
}

<div class="app-page">
    <section class="app-surface rounded-[2rem] px-5 py-5 sm:px-6 sm:py-6 lg:px-8 lg:py-7">
        <div class="flex flex-col gap-6">
            <div class="min-w-0">
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-slate-400 dark:text-slate-500">Рабочее место</p>
                <h1 class="mt-2 text-2xl font-semibold tracking-tight text-slate-950 dark:text-white sm:text-3xl">@Model.FullName</h1>
                <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-slate-500 dark:text-slate-400">
                    <span class="app-status-pill @(Model.HasActiveShift ? "app-status-pill-active" : "app-status-pill-idle")">
                        @(Model.HasActiveShift ? "На смене" : "Вне смены")
                    </span>
                    <span>Сегодня: @FormatDuration(Model.WorkedMinutesToday)</span>
                    <span>Отметок: @Model.ShiftsTodayCount</span>
                    @if (Model.FirstShiftStartToday.HasValue)
                    {
                        <span>Первый вход: @Model.FirstShiftStartToday.Value.ToString("HH:mm")</span>
                    }
                </div>
            </div>

            <div class="app-state-shell">
                <div class="app-state-body">
                    <p class="app-state-kicker @(Model.HasActiveShift ? "text-emerald-600 dark:text-emerald-300" : "text-slate-400 dark:text-slate-500")">@stateTitle</p>
                    <div class="app-state-grid">
                        <div class="app-state-metric">
                            <p class="app-state-label">@leftLabel</p>
                            <p class="app-state-value">@leftValue</p>
                        </div>
                        <div class="app-state-metric">
                            <p class="app-state-label">@rightLabel</p>
                            @if (Model.HasActiveShift && Model.ActiveShiftStartTime.HasValue)
                            {
                                <p data-shift-timer data-shift-start-unix="@(new DateTimeOffset(Model.ActiveShiftStartTime.Value).ToUnixTimeSeconds())" class="app-state-value app-state-value-mono">
                                    00:00:00
                                </p>
                            }
                            else
                            {
                                <p class="app-state-value @(rightValue == "—" ? "text-slate-400 dark:text-slate-500" : string.Empty)">@rightValue</p>
                            }
                        </div>
                    </div>
                    <p class="app-state-note">@helperText</p>
                </div>

                @if (Model.HasActiveShift && Model.ActiveShiftStartTime.HasValue)
                {
                    <form asp-action="EndShift" method="post" class="app-state-action">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="@actionClass">
                            @actionLabel
                        </button>
                    </form>
                }
                else
                {
                    <form asp-action="StartShift" method="post" class="app-state-action">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="@actionClass">
                            @actionLabel
                        </button>
                    </form>
                }
            </div>
        </div>
    </section>

    <section class="app-surface overflow-hidden rounded-[2rem] px-5 py-5 sm:px-6 sm:py-6 lg:px-8">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-slate-400 dark:text-slate-500">История</p>
                <h2 class="mt-1 text-xl font-semibold tracking-tight text-slate-950 dark:text-white">Последние смены</h2>
            </div>
            <a href="/me/shifts" class="app-link-subtle">Вся история</a>
        </div>

        @if (Model.RecentShifts.Any())
        {
            <div class="mt-5 overflow-hidden rounded-[1.5rem] bg-slate-50/80 dark:bg-slate-950/50">
                <div class="app-scrollbar overflow-x-auto">
                    <table class="min-w-full">
                        <thead>
                            <tr class="border-b border-slate-200/70 text-left text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-slate-400 dark:border-slate-800 dark:text-slate-500">
                                <th class="px-4 py-3 sm:px-5">Дата</th>
                                <th class="px-4 py-3 sm:px-5">Начало</th>
                                <th class="px-4 py-3 sm:px-5">Окончание</th>
                                <th class="px-4 py-3 text-right sm:px-5">Длительность</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200/70 text-sm dark:divide-slate-800">
                            @foreach (var shift in Model.RecentShifts)
                            {
                                <tr class="app-table-row">
                                    <td class="px-4 py-4 font-medium text-slate-950 dark:text-white sm:px-5">@shift.StartTime.ToString("dd.MM.yyyy")</td>
                                    <td class="px-4 py-4 text-slate-600 dark:text-slate-300 sm:px-5">@shift.StartTime.ToString("HH:mm")</td>
                                    <td class="px-4 py-4 text-slate-600 dark:text-slate-300 sm:px-5">@(shift.EndTime?.ToString("HH:mm") ?? "В работе")</td>
                                    <td class="px-4 py-4 text-right font-medium text-slate-950 dark:text-white sm:px-5">@FormatDuration(shift.DurationMinutes)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="app-empty-state mt-5">
                <p class="app-empty-state-title">История пока пуста</p>
                <p class="app-empty-state-text">Первая запись появится после начала смены.</p>
            </div>
        }
    </section>
</div>
