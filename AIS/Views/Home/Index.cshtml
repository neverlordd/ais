@model AIS.ViewModels.Home.DashboardViewModel
@{
    ViewData["Title"] = "Главная";
    var hasCompletedShift = Model.LatestShiftStartTimeToday.HasValue && Model.LatestShiftEndTimeToday.HasValue;

    static string FormatDuration(int totalMinutes)
    {
        var safeMinutes = Math.Max(0, totalMinutes);
        var hours = safeMinutes / 60;
        var minutes = safeMinutes % 60;
        return $"{hours:00}:{minutes:00}";
    }
}

<div class="mx-auto max-w-5xl app-page">
    <section class="app-surface rounded-[2rem] px-5 py-5 sm:px-6 sm:py-6 lg:px-8 lg:py-7">
        <div class="flex flex-col gap-6">
            <div class="min-w-0">
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-slate-400 dark:text-slate-500">Рабочее место</p>
                <h1 class="mt-2 text-2xl font-semibold tracking-tight text-slate-950 dark:text-white sm:text-3xl">@Model.FullName</h1>
                <div class="app-meta-row mt-4 text-sm">
                    <span class="app-status-pill @(Model.HasActiveShift ? "app-status-pill-active" : "app-status-pill-idle")">
                        @(Model.HasActiveShift ? "На смене" : "Вне смены")
                    </span>
                    <span class="app-inline-meta-pill">Сегодня: @FormatDuration(Model.WorkedMinutesToday)</span>
                    <span class="app-inline-meta-pill">Отметок: @Model.ShiftsTodayCount</span>
                </div>
            </div>

            @if (Model.HasActiveShift && Model.ActiveShiftStartTime.HasValue)
            {
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-emerald-600 dark:text-emerald-300">Смена активна</p>
                <div class="grid gap-5 lg:grid-cols-[minmax(0,1.15fr)_18rem] lg:items-end">
                    <div class="space-y-4">
                        <div>
                            <p class="text-sm text-slate-500 dark:text-slate-400">Начало</p>
                            <p class="mt-1 text-3xl font-semibold tracking-tight text-slate-950 dark:text-white">@Model.ActiveShiftStartTime.Value.ToString("HH:mm")</p>
                        </div>
                        <div>
                            <p class="text-sm text-slate-500 dark:text-slate-400">Продолжительность</p>
                            <p data-shift-timer data-shift-start-unix="@(new DateTimeOffset(Model.ActiveShiftStartTime.Value).ToUnixTimeSeconds())" class="mt-1 font-mono text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">
                                00:00:00
                            </p>
                        </div>
                    </div>

                    <div class="grid gap-4">
                        <div class="app-stat-card">
                            <p class="app-stat-label">Первый вход</p>
                            <p class="app-stat-value">@(Model.FirstShiftStartToday?.ToString("HH:mm") ?? "—")</p>
                            <p class="app-stat-note">Первая отметка за текущий день</p>
                        </div>
                        <form asp-action="EndShift" method="post" class="flex">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="app-button app-button-danger min-h-14 w-full justify-center rounded-[1.25rem] px-5 text-sm font-semibold">
                                Завершить смену
                            </button>
                        </form>
                    </div>
                </div>
            }
            else if (hasCompletedShift)
            {
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-slate-400 dark:text-slate-500">Последняя смена сегодня</p>
                <div class="grid gap-5 lg:grid-cols-[minmax(0,1.15fr)_18rem] lg:items-end">
                    <div class="grid gap-4 sm:grid-cols-2">
                        <div>
                            <p class="text-sm text-slate-500 dark:text-slate-400">Приход</p>
                            <p class="mt-1 text-3xl font-semibold tracking-tight text-slate-950 dark:text-white">@Model.LatestShiftStartTimeToday!.Value.ToString("HH:mm")</p>
                        </div>
                        <div>
                            <p class="text-sm text-slate-500 dark:text-slate-400">Уход</p>
                            <p class="mt-1 text-3xl font-semibold tracking-tight text-slate-950 dark:text-white">@Model.LatestShiftEndTimeToday!.Value.ToString("HH:mm")</p>
                        </div>
                    </div>

                    <div class="grid gap-4">
                        <div class="app-stat-card">
                            <p class="app-stat-label">Первый вход</p>
                            <p class="app-stat-value">@(Model.FirstShiftStartToday?.ToString("HH:mm") ?? "—")</p>
                            <p class="app-stat-note">Все отметки за день уже завершены</p>
                        </div>
                        <form asp-action="StartShift" method="post" class="flex">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="app-button app-button-primary min-h-14 w-full justify-center rounded-[1.25rem] px-5 text-sm font-semibold">
                                Начать новую смену
                            </button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-slate-400 dark:text-slate-500">Смена</p>
                <div class="grid gap-5 lg:grid-cols-[minmax(0,1.15fr)_18rem] lg:items-end">
                    <div>
                        <p class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">Сегодня отметок нет</p>
                        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Запустите смену в начале работы.</p>
                    </div>

                    <div class="grid gap-4">
                        <div class="app-stat-card">
                            <p class="app-stat-label">Первый вход</p>
                            <p class="app-stat-value">—</p>
                            <p class="app-stat-note">Запись появится после начала смены</p>
                        </div>
                        <form asp-action="StartShift" method="post" class="flex">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="app-button app-button-primary min-h-14 w-full justify-center rounded-[1.25rem] px-5 text-sm font-semibold">
                                Начать смену
                            </button>
                        </form>
                    </div>
                </div>
            }

            <div class="app-stat-grid">
                <div class="app-stat-card">
                    <p class="app-stat-label">За сегодня</p>
                    <p class="app-stat-value">@FormatDuration(Model.WorkedMinutesToday)</p>
                    <p class="app-stat-note">Суммарное время за текущий день</p>
                </div>
                <div class="app-stat-card">
                    <p class="app-stat-label">Первый вход</p>
                    <p class="app-stat-value">@(Model.FirstShiftStartToday?.ToString("HH:mm") ?? "—")</p>
                    <p class="app-stat-note">Первая отметка сегодня</p>
                </div>
                <div class="app-stat-card">
                    <p class="app-stat-label">Отметки</p>
                    <p class="app-stat-value">@Model.ShiftsTodayCount</p>
                    <p class="app-stat-note">Количество запусков смены за день</p>
                </div>
            </div>
        </div>
    </section>

    <section class="app-surface overflow-hidden rounded-[2rem] px-5 py-5 sm:px-6 sm:py-6 lg:px-8">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-slate-400 dark:text-slate-500">История</p>
                <h2 class="mt-1 text-xl font-semibold tracking-tight text-slate-950 dark:text-white">Последние смены</h2>
            </div>
            <a href="/me/shifts" class="app-link-subtle">Вся история</a>
        </div>

        @if (Model.RecentShifts.Any())
        {
            <div class="mt-5 overflow-hidden rounded-[1.5rem] bg-slate-50/80 dark:bg-slate-950/50">
                <div class="app-scrollbar overflow-x-auto">
                    <table class="min-w-full">
                        <thead>
                            <tr class="border-b border-slate-200/70 text-left text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-slate-400 dark:border-slate-800 dark:text-slate-500">
                                <th class="px-4 py-3 sm:px-5">Дата</th>
                                <th class="px-4 py-3 sm:px-5">Начало</th>
                                <th class="px-4 py-3 sm:px-5">Окончание</th>
                                <th class="px-4 py-3 text-right sm:px-5">Длительность</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200/70 text-sm dark:divide-slate-800">
                            @foreach (var shift in Model.RecentShifts)
                            {
                                <tr class="app-table-row">
                                    <td class="px-4 py-4 font-medium text-slate-950 dark:text-white sm:px-5">@shift.StartTime.ToString("dd.MM.yyyy")</td>
                                    <td class="px-4 py-4 text-slate-600 dark:text-slate-300 sm:px-5">@shift.StartTime.ToString("HH:mm")</td>
                                    <td class="px-4 py-4 text-slate-600 dark:text-slate-300 sm:px-5">@(shift.EndTime?.ToString("HH:mm") ?? "В работе")</td>
                                    <td class="px-4 py-4 text-right font-medium text-slate-950 dark:text-white sm:px-5">@FormatDuration(shift.DurationMinutes)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="app-empty-state mt-5">
                <p class="app-empty-state-title">История пока пуста</p>
                <p class="app-empty-state-text">Первая запись появится после начала смены.</p>
            </div>
        }
    </section>
</div>
