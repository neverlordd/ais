@model AIS.ViewModels.Home.DashboardViewModel
@{
    ViewData["Title"] = "Главная";
    var hasCompletedShift = Model.LatestShiftStartTimeToday.HasValue && Model.LatestShiftEndTimeToday.HasValue;
}

<div class="mx-auto max-w-5xl">
    <section class="rounded-[2rem] border border-slate-200/80 bg-white/95 p-5 shadow-soft dark:border-slate-800 dark:bg-slate-900/95 sm:p-6 lg:p-8">
        <div class="flex flex-col gap-5 border-b border-slate-200 pb-5 dark:border-slate-800 lg:flex-row lg:items-start lg:justify-between">
            <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">Сотрудник</p>
                <h1 class="mt-2 text-2xl font-semibold tracking-tight text-slate-950 dark:text-white sm:text-3xl">@Model.FullName</h1>
                <div class="mt-3 flex flex-wrap items-center gap-3">
                    <p class="text-sm text-slate-500 dark:text-slate-400">@Model.Role.GetDisplayName()</p>
                    @if (Model.HasActiveShift)
                    {
                        <span class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-sm font-medium text-emerald-700 dark:border-emerald-950 dark:bg-emerald-950/50 dark:text-emerald-200">
                            На смене
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm font-medium text-slate-600 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-300">
                            Не на смене
                        </span>
                    }
                </div>
            </div>

            <div class="rounded-[1.5rem] border border-brand-100 bg-brand-50/80 p-4 dark:border-brand-900/70 dark:bg-brand-950/30 sm:min-w-[14rem]">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-700 dark:text-brand-100">Сейчас</p>
                <p data-live-clock class="mt-2 font-mono text-2xl font-semibold tracking-tight text-slate-950 dark:text-white sm:text-3xl">00:00:00</p>
            </div>
        </div>

        <div class="mt-5 grid gap-4 lg:grid-cols-[minmax(0,1fr)_20rem] lg:items-stretch">
            <div class="rounded-[1.6rem] border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-950/80 sm:p-5">
                @if (Model.HasActiveShift && Model.ActiveShiftStartTime.HasValue)
                {
                    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-600 dark:text-emerald-300">Активная смена</p>
                    <div class="mt-4 grid gap-4 sm:grid-cols-2">
                        <div>
                            <p class="text-sm text-slate-500 dark:text-slate-400">Начало</p>
                            <p class="mt-1 text-xl font-semibold text-slate-950 dark:text-white">@Model.ActiveShiftStartTime.Value.ToString("HH:mm")</p>
                        </div>
                        <div>
                            <p class="text-sm text-slate-500 dark:text-slate-400">Продолжительность</p>
                            <p data-shift-timer data-shift-start-unix="@(new DateTimeOffset(Model.ActiveShiftStartTime.Value).ToUnixTimeSeconds())" class="mt-1 font-mono text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">
                                00:00:00
                            </p>
                        </div>
                    </div>
                }
                else if (hasCompletedShift)
                {
                    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">Последняя смена за сегодня</p>
                    <div class="mt-4 grid gap-4 sm:grid-cols-2">
                        <div>
                            <p class="text-sm text-slate-500 dark:text-slate-400">Начало</p>
                            <p class="mt-1 text-xl font-semibold text-slate-950 dark:text-white">@Model.LatestShiftStartTimeToday!.Value.ToString("HH:mm")</p>
                        </div>
                        <div>
                            <p class="text-sm text-slate-500 dark:text-slate-400">Окончание</p>
                            <p class="mt-1 text-xl font-semibold text-slate-950 dark:text-white">@Model.LatestShiftEndTimeToday!.Value.ToString("HH:mm")</p>
                        </div>
                    </div>
                }
                else
                {
                    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">Статус</p>
                    <p class="mt-4 text-lg font-semibold text-slate-950 dark:text-white">Смена еще не начата</p>
                }
            </div>

            <div class="flex items-stretch">
                @if (Model.HasActiveShift)
                {
                    <form asp-action="EndShift" method="post" class="flex w-full">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="min-h-16 w-full rounded-[1.6rem] bg-rose-600 px-6 py-5 text-base font-semibold text-white transition hover:bg-rose-700">
                            Завершить смену
                        </button>
                    </form>
                }
                else
                {
                    <form asp-action="StartShift" method="post" class="flex w-full">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="min-h-16 w-full rounded-[1.6rem] bg-slate-900 px-6 py-5 text-base font-semibold text-white transition hover:bg-slate-700 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200">
                            Начать смену
                        </button>
                    </form>
                }
            </div>
        </div>
    </section>
</div>
