@model AIS.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "Авторизация";
    var returnUrl = ViewData["ReturnUrl"]?.ToString();
}

<div class="mx-auto flex min-h-[calc(100vh-10rem)] max-w-6xl items-center justify-center">
    <div class="grid w-full gap-6 lg:grid-cols-[1.05fr_0.95fr]">
        <section class="hidden rounded-[2rem] border border-slate-200/80 bg-white/90 p-8 shadow-soft dark:border-slate-800 dark:bg-slate-900/90 lg:flex lg:flex-col lg:justify-between xl:p-10">
            <div>
                <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-600 dark:text-brand-100">ShiftLine</p>
                <h1 class="mt-4 max-w-xl text-4xl font-semibold leading-tight text-balance text-slate-950 dark:text-white">
                    Учет рабочего времени без лишних действий.
                </h1>
                <p class="mt-5 max-w-xl text-base leading-7 text-slate-600 dark:text-slate-300">
                    Авторизация сотрудника, фиксация смен и административный контроль в одном интерфейсе.
                </p>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
                <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5 dark:border-slate-800 dark:bg-slate-950/80">
                    <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Вход</p>
                    <p class="mt-2 text-lg font-semibold text-slate-950 dark:text-white">Быстрый и понятный сценарий</p>
                </div>
                <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5 dark:border-slate-800 dark:bg-slate-950/80">
                    <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Смены</p>
                    <p class="mt-2 text-lg font-semibold text-slate-950 dark:text-white">Точное время начала и окончания</p>
                </div>
            </div>
        </section>

        <section class="rounded-[2rem] border border-slate-200/80 bg-white/95 p-6 shadow-soft dark:border-slate-800 dark:bg-slate-900/95 sm:p-8 lg:p-10">
            <div class="mb-6 sm:mb-8">
                <p class="text-sm font-semibold uppercase tracking-[0.28em] text-slate-500 dark:text-slate-400">Вход в систему</p>
                <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950 dark:text-white">Авторизация сотрудника</h2>
                <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">
                    Введите логин и пароль.
                </p>
            </div>

            <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post" class="space-y-5">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700 dark:border-rose-950 dark:bg-rose-950/60 dark:text-rose-200"></div>

                <div class="space-y-2">
                    <label asp-for="Username" class="text-sm font-medium text-slate-700 dark:text-slate-200"></label>
                    <input asp-for="Username" class="w-full rounded-2xl border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm transition placeholder:text-slate-400 focus:border-brand-500 focus:ring-brand-500 dark:border-slate-700 dark:bg-slate-950 dark:text-white dark:placeholder:text-slate-500" placeholder="Введите логин" />
                    <span asp-validation-for="Username" class="text-sm text-rose-600 dark:text-rose-300"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Password" class="text-sm font-medium text-slate-700 dark:text-slate-200"></label>
                    <input asp-for="Password" class="w-full rounded-2xl border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm transition placeholder:text-slate-400 focus:border-brand-500 focus:ring-brand-500 dark:border-slate-700 dark:bg-slate-950 dark:text-white dark:placeholder:text-slate-500" placeholder="Введите пароль" />
                    <span asp-validation-for="Password" class="text-sm text-rose-600 dark:text-rose-300"></span>
                </div>

                <button type="submit" class="inline-flex min-h-12 w-full items-center justify-center rounded-2xl bg-slate-900 px-5 py-3.5 text-sm font-semibold text-white transition hover:bg-slate-700 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200">
                    Войти
                </button>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
