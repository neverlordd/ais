@model AIS.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "Авторизация";
    var returnUrl = ViewData["ReturnUrl"]?.ToString();
}

<div class="mx-auto flex min-h-[calc(100vh-10rem)] max-w-6xl items-center justify-center">
    <div class="grid w-full gap-6 lg:grid-cols-[1.05fr_0.95fr]">
        <section class="app-form-card hidden lg:flex lg:flex-col lg:justify-between xl:p-10">
            <div>
                <p class="text-sm font-semibold uppercase tracking-[0.3em] text-brand-600 dark:text-brand-100">ShiftLine</p>
                <h1 class="mt-4 max-w-xl text-4xl font-semibold leading-tight text-balance text-slate-950 dark:text-white">
                    Учет рабочего времени без лишних действий.
                </h1>
                <p class="mt-5 max-w-xl text-base leading-7 text-slate-600 dark:text-slate-300">
                    Авторизация сотрудника, фиксация смен и административный контроль в одном интерфейсе.
                </p>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
                <div class="app-muted-surface rounded-3xl p-5">
                    <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Вход</p>
                    <p class="mt-2 text-lg font-semibold text-slate-950 dark:text-white">Быстрый и понятный сценарий</p>
                </div>
                <div class="app-muted-surface rounded-3xl p-5">
                    <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Смены</p>
                    <p class="mt-2 text-lg font-semibold text-slate-950 dark:text-white">Точное время начала и окончания</p>
                </div>
            </div>
        </section>

        <section class="app-form-card p-6 sm:p-8 lg:p-10">
            <div class="app-section-header mb-6 sm:mb-8">
                <p class="app-section-kicker">Вход в систему</p>
                <h2 class="app-section-title">Авторизация сотрудника</h2>
                <p class="app-section-description">
                    Введите логин и пароль.
                </p>
            </div>

            <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post" class="space-y-5">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="app-validation-summary"></div>

                <div class="app-field">
                    <label asp-for="Username" class="app-label"></label>
                    <input asp-for="Username" class="app-input" placeholder="Введите логин" />
                    <span asp-validation-for="Username" class="app-validation"></span>
                </div>

                <div class="app-field">
                    <label asp-for="Password" class="app-label"></label>
                    <input asp-for="Password" class="app-input" placeholder="Введите пароль" />
                    <span asp-validation-for="Password" class="app-validation"></span>
                </div>

                <button type="submit" class="app-button app-button-primary min-h-12 w-full rounded-2xl px-5 py-3.5 text-sm font-semibold">
                    Войти
                </button>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
